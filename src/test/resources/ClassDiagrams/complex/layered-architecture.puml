@startuml
title Class Diagram Example
header Generated by PlantUML
footer Page 1 of 1

package "Application Layer" #LightBlue {
    class ApplicationService {
        -userRepository: UserRepository
        -orderRepository: OrderRepository
        +createUser(name: String): User
        +placeOrder(userId: long, items: List): Order
    }
}

package "Domain Layer" #LightGreen {
    abstract class Entity {
        #id: long
        +getId(): long
    }

    class User extends Entity {
        -name: String
        -email: String
        -orders: List<Order>
        +getName(): String
        +addOrder(order: Order): void
    }

    class Order extends Entity {
        -orderDate: Date
        -status: OrderStatus
        -lines: List<OrderLine>
        +calculateTotal(): double
    }

    class OrderLine {
        -quantity: int
        -unitPrice: double
        -product: Product
        +getSubtotal(): double
    }

    class Product {
        -sku: String
        -name: String
        -price: double
    }

    enum OrderStatus {
        PENDING
        CONFIRMED
        SHIPPED
        DELIVERED
    }
}

package "Infrastructure Layer" #LightYellow {
    interface UserRepository {
        +save(user: User): User
        +findById(id: long): User
    }

    interface OrderRepository {
        +save(order: Order): Order
        +findByUser(userId: long): List<Order>
    }

    class JpaUserRepository implements UserRepository
    class JpaOrderRepository implements OrderRepository
}

User "1" -- "0..*" Order : places >
Order "1" *-- "1..*" OrderLine : contains
OrderLine "0..*" --> "1" Product : references
Order --> OrderStatus : has

ApplicationService --> UserRepository
ApplicationService --> OrderRepository

note right of User
    User is the main
    aggregate root
end note
@enduml