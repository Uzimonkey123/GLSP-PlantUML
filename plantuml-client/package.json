{
  "name": "plantuml-glsp",
  "version": "1.0.0",
  "private": true,
  "main": "./extension/dist/extension.js",
  "workspaces": [
    "client",
    "extension",
    "webview"
  ],
  "engines": {
    "vscode": "^1.100.0"
  },
  "scripts": {
    "build:client": "npm run --workspace=client build",
    "build:extension": "npm run --workspace=extension build",
    "build:webview": "npm run --workspace=webview build",
    "build:all": "npm run build:client && npm run build:webview && npm run build:extension"
  },
  "activationEvents": [
    "onLanguage:plantuml",
    "onCustomEditor:plantuml.glspDiagram",
    "onCommand:plantuml.openPreview"
  ],
  "contributes": {
    "languages": [
      {
        "id": "plantuml",
        "name": "PlantUML",
        "aliases": [
          "PlantUML",
          "puml"
        ],
        "extensions": [
          ".puml"
        ]
      }
    ],
    "commands": [
      {
        "command": "plantuml.openPreview",
        "title": "Open PlantUML Preview"
      },
      {
        "command": "plantuml.exportSvg",
        "title": "PlantUML: Export diagram as SVG"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "plantuml.openPreview",
          "when": "resourceExtname == .puml",
          "group": "navigation"
        }
      ]
    },
    "customEditors": [
      {
        "viewType": "plantuml.glspDiagram",
        "displayName": "PlantUML Diagram",
        "selector": [
          {
            "filenamePattern": "*.puml"
          }
        ],
        "priority": "option"
      }
    ]
  },
  "devDependencies": {
    "@types/react": "^19.1.8",
    "circular-dependency-plugin": "^5.2.2",
    "copy-webpack-plugin": "^13.0.0",
    "copyfiles": "^2.4.1",
    "css-loader": "^7.1.2",
    "rimraf": "^5.0.0",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.2",
    "typescript": "^5.8.3",
    "webpack": "^5.99.9",
    "webpack-cli": "^6.0.1"
  },
  "dependencies": {
    "@eclipse-glsp/client": "^2.4.0",
    "@eclipse-glsp/ts-config": "^2.4.0",
    "@eclipse-glsp/vscode-integration": "^2.4.0",
    "@eclipse-glsp/vscode-integration-webview": "^2.4.0",
    "@vscode/codicons": "^0.0.36",
    "inversify": "^6.1.3",
    "react": "^19.1.0",
    "vscode-languageclient": "^9.0.1"
  }
}
